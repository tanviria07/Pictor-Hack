# Used by docker-compose (root). Copy to .env and customize.

# --- Host port mappings ---
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8080
RUNNER_HOST_PORT=8001
REDIS_HOST_PORT=6379

# --- Browser CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Go API (also read inside backend container; compose overrides many of these) ---
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Gemini (Jose voice coach) — server-side only, never shipped to browser ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Redis run queue (worker + backend; compose sets REDIS_URL for services) ---
RUN_QUEUE_KEY=run:queue
RUN_JOB_KEY_PREFIX=run:job:
RUN_REQ_KEY_PREFIX=run:req:
RUN_RAW_RESULT_PREFIX=run:raw:
RUN_FINAL_RESULT_PREFIX=run:final:
RUN_FINALIZE_LOCK_PREFIX=run:finalize-lock:
RUN_JOB_TTL_SEC=3600

# --- Python runner / worker ---
RUNNER_USE_SUBPROCESS=1
RUNNER_SUBPROCESS_TIMEOUT_SEC=30
RUNNER_CORS_ORIGINS=*
