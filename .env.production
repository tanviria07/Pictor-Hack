# --- Site Configuration ---
SITE_ADDRESS=kitkode.example.com
ADMIN_EMAIL=admin@example.com

# --- Backend Secrets ---
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=replace_me_with_a_long_random_string

# --- Database ---
DATABASE_PATH=./data/pictorhack.db

# --- Optional AI Integrations ---
# Required for natural-language feedback and proactive coaching
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Security ---
# Comma-separated list of allowed origins. Usually just your SITE_ADDRESS.
CORS_ORIGINS=https://kitkode.example.com
# Set to true for HTTPS production environments
SECURE_COOKIES=true

# --- Resource Limits ---
# Limit the number of concurrent executions or request sizes
RATE_LIMIT_PER_MINUTE=60
MAX_CODE_BYTES=262144
