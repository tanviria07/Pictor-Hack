PORT=8080
DATABASE_PATH=./data/pictorhack.db
RUNNER_URL=http://127.0.0.1:8001
# Comma-separated browser Origins (localhost vs 127.0.0.1 differ). Defaults match both :3000.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# POST /api/run payload limits and abuse protection
MAX_CODE_BYTES=262144
RATE_LIMIT_PER_MINUTE=120

# Optional â€” interviewer-style phrasing only; correctness stays in the Python runner
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Async runs (optional): set REDIS_URL to enable POST /api/run/jobs + worker queue
REDIS_URL=
RUN_QUEUE_KEY=run:queue
RUN_JOB_KEY_PREFIX=run:job:
RUN_REQ_KEY_PREFIX=run:req:
RUN_RAW_RESULT_PREFIX=run:raw:
RUN_FINAL_RESULT_PREFIX=run:final:
RUN_FINALIZE_LOCK_PREFIX=run:finalize-lock:
RUN_JOB_TTL_SEC=3600

# Docker / dev: load problems from disk instead of embed (same tree as shared/problems)
PROBLEMS_DATA_DIR=
