RUNNER_USE_SUBPROCESS=1
RUNNER_SUBPROCESS_TIMEOUT_SEC=6
RUNNER_CORS_ORIGINS=*

# Optional: Docker-backed sandbox (requires Docker daemon + image built from Dockerfile.sandbox).
# RUNNER_USE_DOCKER=1
# RUNNER_USE_SUBPROCESS=0
# RUNNER_DOCKER_IMAGE=pictorhack-runner-sandbox:latest
# RUNNER_DOCKER_TIMEOUT_SEC=8
# RUNNER_DOCKER_MEMORY=256m
# RUNNER_DOCKER_CPUS=1
# When the runner runs inside Docker Compose, set this to a host-bind path the engine can read
# (e.g. mount `.:/workspace` and use /workspace/.runner-jobs).
# RUNNER_DOCKER_JOB_DIR=
