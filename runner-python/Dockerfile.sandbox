# Minimal image for isolated code runs (bind-mount repo at /sandbox at runtime).
# Build: docker build -f Dockerfile.sandbox -t pictorhack-runner-sandbox:latest .
FROM python:3.12-slim

WORKDIR /sandbox

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Real app tree is supplied read-only via `docker run -v ...:/sandbox:ro`.
