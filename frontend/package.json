{
  "name": "kitkode-frontend",
  "description": "Kitkode frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-with-local-temp.mjs parcel index.html --port 3000 --host 127.0.0.1",
    "build": "node ./scripts/run-with-local-temp.mjs parcel build index.html --dist-dir dist",
    "lint": "eslint . --ext js,jsx --max-warnings 0",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "parcel": "^2.14.4"
  }
}
