# Optional: set to a full API URL only if the browser must call the API directly
# (e.g. frontend and API on different deployed hosts). Otherwise leave unset so
# requests go to /api on this origin and next.config.mjs proxies to the Go server.
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080

# Target for the dev/prod rewrite proxy (Next.js server → Go). Default: http://127.0.0.1:8080
# BACKEND_URL=http://127.0.0.1:8080
