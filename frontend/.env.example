# Optional: full API origin if the browser must call the API on another host.
# Leave unset in dev so requests use /api and the Parcel dev proxy (.proxyrc.json) forwards to the Go server.
# API_BASE=http://127.0.0.1:8080

# Dev proxy target (edit .proxyrc.json if your API is not on :8080).

# Use async run queue when set to 1 (requires API + worker support). Baked in at build time for production.
# ASYNC_RUN=1
