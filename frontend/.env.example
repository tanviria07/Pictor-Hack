# ---------------------------------------------------------------------------
# Frontend env. Parcel 2 inlines these at build/dev time from `frontend/.env`.
# Copy this file to `frontend/.env` and edit values locally.
# ---------------------------------------------------------------------------

# Full API origin when the browser must call the backend on another host.
# Leave unset in dev: requests go to /api and the Parcel proxy (.proxyrc.json)
# forwards to the Go server on :8080.
# API_BASE=http://127.0.0.1:8080

# ---- Jose voice coach (Gemini) ----
# Disabled by default. Set to true only when actively testing the optional
# coach panel and microphone flow.
ENABLE_VOICE_COACH=false
# VITE_ENABLE_VOICE_COACH=false

# Get an API key from https://aistudio.google.com/app/apikey
# Either prefix is accepted; VITE_ is kept for backward compatibility with
# earlier versions.
# GEMINI_API_KEY=your_google_ai_studio_key
# GEMINI_MODEL=gemini-2.5-flash
