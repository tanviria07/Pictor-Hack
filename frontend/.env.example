# ---------------------------------------------------------------------------
# Frontend env. Parcel 2 inlines these at build/dev time from `frontend/.env`.
# Copy this file to `frontend/.env` and edit values locally.
# ---------------------------------------------------------------------------

# Full API origin when the browser must call the backend on another host.
# Leave unset in dev: requests go to /api and the Parcel proxy (.proxyrc.json)
# forwards to the Go server on :8080. For Cloudflare Pages production builds
# set this to the Fly.io API origin, e.g. https://kitkode-api.fly.dev.
# API_BASE=http://127.0.0.1:8080

# Async run queue (requires REDIS_URL on the API + runner worker). Baked in
# at build time for the production Docker image.
# ASYNC_RUN=1

# ---- Jose voice coach ----
# The Gemini API key now lives on the Go API (GEMINI_API_KEY server-side).
# The browser only needs to decide whether to render the Jose widget at all.
# Set to 0/false/no/off to hide the voice coach UI in a given build.
# VOICE_COACH_ENABLED=1
